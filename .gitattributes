# Enforce LF line endings for text files regardless of platform
# Prevents CRLF commits from Windows editors breaking shell scripts on WSL/Linux

# Shell and scripting
*.sh        text eol=lf
*.bash      text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf

# R scripts
*.R         text eol=lf
*.r         text eol=lf

# Config and markup
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.svg       text eol=lf

# Git config
.gitignore  text eol=lf
.gitattributes text eol=lf

# Additional text types (normalise to LF — some previously carried CRLF blobs)
*.bib          text eol=lf
*.qmd          text eol=lf
*.mmd          text eol=lf
*.webmanifest  text eol=lf
*.lock         text eol=lf
.Rprofile      text eol=lf
LICENSE        text eol=lf

# Gap-closure: tracked text types that had no prior eol rule (LF-clean today; ruled so a
# future CRLF commit is auto-repairable by `git add --renormalize`, not merely caught by the gate)
*.py            text eol=lf
Dockerfile      text eol=lf
.dockerignore   text eol=lf

# Binary assets — no normalisation
*.webp      binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.ico       binary
